# .env file

# OpenAI API key configuration. Get your API key from https://platform.openai.com/account/api-keys and set it here.
OPENAI_API_KEY=your_openai_api_key_here

# Admin access configuration
ADMIN_PASSWORD=choose_a_strong_password
ADMIN_TOKEN_SECRET=choose_a_random_secret

# Server configuration. To access the server, go to http://localhost:3000 in your browser.
PORT=3000

# Contact form (help popup). Get an API key from https://resend.com/api-keys.
# CONTACT_FROM_EMAIL must be on a domain verified in Resend, or omit it to use
# Resend's shared sandbox address (onboarding@resend.dev).
RESEND_API_KEY=your_resend_api_key_here
CONTACT_TO_EMAIL=you@example.com
CONTACT_FROM_EMAIL=Nexy Contact Form <onboarding@resend.dev>